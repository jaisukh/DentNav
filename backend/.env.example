# PostgreSQL (async). Local docker-compose maps Postgres to host port 15432.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:15432/dentnav

BACKEND_CORS_ORIGINS=http://localhost:3000,https://dentnav.vercel.app
# Optional regex for Vercel preview URLs
CORS_ORIGIN_REGEX=^https://[^/]+\.vercel\.app$

FRONTEND_BASE_URL=http://localhost:3000

# Questionnaire: S3 (production) or bundled local JSON when unset
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_QUESTIONNAIRE_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Google OAuth (browser redirect flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# OpenAI analysis
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
