# ─────────────────────────────────────────────────────────────────────────────
# DentNav — environment variables reference
# Copy this file to .env and fill in real values for local development.
# Railway (backend) and Vercel (frontend) receive these via their dashboards.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Async URL used by the FastAPI app and Alembic migrations.
# Local docker-compose exposes Postgres on port 15432.
# Railway injects a Railway-managed DATABASE_URL automatically.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:15432/dentnav

# ── CORS / Frontend ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the backend.
# Add your Railway backend URL and Vercel production URL here for production.
BACKEND_CORS_ORIGINS=http://localhost:3000,https://dentnav.vercel.app
# Optional regex to allow all Vercel preview deployments automatically.
# Used by the backend to build redirect URLs after OAuth (e.g. auth callback).
FRONTEND_BASE_URL=http://localhost:3000

# ── AWS S3 (questionnaire storage) ──────────────────────────────────────────
# Leave S3 vars empty to fall back to the bundled local questionnaire JSON.
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_QUESTIONNAIRE_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
#   Local:      http://localhost:8000/api/v1/auth/google/callback
#   Production: https://<your-railway-backend>/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Frontend (Vercel / Docker) ───────────────────────────────────────────────
# Set this to the Railway backend URL in the Vercel dashboard for production.
# Must be a NEXT_PUBLIC_ var so it is embedded at build time.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
